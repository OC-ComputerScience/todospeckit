{
  "name": "todo-speckit",
  "private": true,
  "description": "Spec-driven todo app — monorepo root (deploy scripts orchestrate frontend/ and backend/)",
  "scripts": {
    "build:frontend": "npm run build --prefix frontend",
    "bundle:frontend": "npm run bundle --prefix frontend",
    "bundle:backend": "npm run bundle --prefix backend",
    "bundle": "npm run bundle:backend && npm run build:frontend && npm run bundle:frontend",
    "test": "npm run test --prefix backend && npm run test --prefix frontend",
    "test:backend": "npm run test --prefix backend",
    "test:frontend": "npm run test --prefix frontend",
    "specs:pdf": "node scripts/export-specs-pdf.mjs full",
    "specs:pdf:features": "node scripts/export-specs-pdf.mjs features",
    "specs:pdf:all": "node scripts/export-specs-pdf.mjs all",
    "specs:pdf:setup": "npx puppeteer browsers install chrome",
    "agility:export": "node scripts/export-agility-import.mjs --project \"Todo Speckit\"",
    "agility:push": "node scripts/push-agility-api.mjs",
    "agility:push:dry-run": "node scripts/push-agility-api.mjs --dry-run",
    "agility:verify": "node scripts/push-agility-api.mjs --verify"
  },
  "devDependencies": {
    "md-to-pdf": "^5.2.4"
  }
}
