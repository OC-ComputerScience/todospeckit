# Digital.ai Agility API — copy to .env.agility (do not commit tokens)
#
# Create token: Agility → My Settings → Access Tokens
# Docs: https://docs.digital.ai/agility/docs/developerlibrary/access-token-authentication

AGILITY_BASE_URL=https://your-instance.com
AGILITY_ACCESS_TOKEN=1.your-access-token-here
AGILITY_SCOPE=Todo Speckit
